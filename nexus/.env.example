# Copia a .env.local y rellena. Next.js lee .env* solo desde esta carpeta (nexus/) al correr en nexus/.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Puede ser clave publishable (sb_publishable_...) o anon legacy (eyJ...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=

# Solo para npm run seed: JWT con rol service_role (nunca en NEXT_PUBLIC_ ni en build del sitio).
# SUPABASE_SERVICE_ROLE_KEY=
